<div class="cartes-cats-dealer">
  <div class="cc-row cc-deck-info">
    <div class="cc-pile" style="background-image:url('{{cardBack}}')">
      <span class="cc-pile-count">{{remaining}}</span>
    </div>
    <div class="cc-deck-meta">
      <strong>{{localize "CARTESCATS.DeckName"}}</strong>
      <span class="cc-remaining-label">{{localize "CARTESCATS.RemainingCards"}} : {{remaining}}</span>
      <button type="button" data-action="reset"><i class="fa-solid fa-rotate"></i> {{localize "CARTESCATS.ResetDeck"}}</button>
    </div>
  </div>

  <div class="cc-columns">
    <div class="cc-column cc-available" data-zone="available">
      <h3>{{localize "CARTESCATS.AvailablePlayers"}}</h3>
      <ul class="cc-player-list">
        {{#each available}}
        <li class="cc-player" draggable="true" data-user-id="{{this.id}}">
          <img src="{{this.avatar}}" alt="" />
          <span>{{this.name}}</span>
        </li>
        {{/each}}
      </ul>
    </div>
    <div class="cc-column cc-participants" data-zone="participants">
      <h3>{{localize "CARTESCATS.Participants"}}</h3>
      <ul class="cc-player-list">
        {{#each participants}}
        <li class="cc-player" draggable="true" data-user-id="{{this.id}}">
          <img src="{{this.avatar}}" alt="" />
          <span>{{this.name}}</span>
          <input type="number" class="cc-participant-count" min="1" value="{{this.count}}" data-user-id="{{this.id}}" title="{{localize 'CARTESCATS.CardsPerPlayer'}}" />
          {{#if this.cardCount}}<span class="cc-recap-badge">{{this.cardCount}}</span>{{/if}}
        </li>
        {{/each}}
      </ul>
    </div>
  </div>

  <p class="cc-hint">{{localize "CARTESCATS.DragHint"}}</p>

  <div class="cc-shuffle-stage" hidden>
    <div class="cc-card cc-card-1" style="background-image:url('{{cardBack}}')"></div>
    <div class="cc-card cc-card-2" style="background-image:url('{{cardBack}}')"></div>
    <div class="cc-card cc-card-3" style="background-image:url('{{cardBack}}')"></div>
    <div class="cc-card cc-card-4" style="background-image:url('{{cardBack}}')"></div>
  </div>

  <footer class="cc-actions">
    <button type="button" data-action="shuffle"><i class="fa-solid fa-shuffle"></i> {{localize "CARTESCATS.Shuffle"}}</button>
    <button type="button" data-action="deal"><i class="fa-solid fa-hand-holding"></i> {{localize "CARTESCATS.Deal"}}</button>
  </footer>
</div>
