<div class="cartes-cats-hand">
  {{#if empty}}
  <p class="cc-empty">{{localize "CARTESCATS.NoCardsYet"}}</p>
  {{else}}
  <ul class="cc-hand-grid">
    {{#each cards}}
    <li class="cc-hand-card">
      <img src="{{this.img}}" alt="{{this.name}}" />
      <span>{{this.name}}</span>
      <button type="button" data-action="use" data-instance-id="{{this.id}}">{{localize "CARTESCATS.UseCard"}}</button>
    </li>
    {{/each}}
  </ul>
  {{/if}}
</div>
